{
  "name": "pashar-proxy",
  "main": "worker.js",
  "assets": {
    "directory": "./Htmel"
  },
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pashar-proxy-db",
      "database_id": "e16d3fec-12f5-4c14-9866-6554cf694f54"
    }
  ],
  "vars": {
    "ENABLE_CRON": "false",
    "PAGES_URL": "https://raw.githubusercontent.com/yasharmasoumizade-ship-it/Nova-Proxy/main/Htmel"
  }
}
